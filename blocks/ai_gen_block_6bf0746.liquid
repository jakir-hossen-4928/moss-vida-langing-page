
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-wellness-hero-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    background: {{ block.settings.gradient_start }};
    {% if block.settings.enable_gradient %}
      background: linear-gradient(
        {{ block.settings.gradient_angle }}deg,
        {{ block.settings.gradient_start }} 0%,
        {{ block.settings.gradient_end }} 100%
      );
    {% endif %}
    color: {{ block.settings.text_color }};
  }

  .ai-wellness-hero-bg-{{ ai_gen_id }} {
    position: absolute;
    inset: 0;
    opacity: {{ block.settings.bg_image_opacity }};
    background-size: {{ block.settings.bg_image_size }};
    background-position: {{ block.settings.bg_image_position }};
    background-repeat: no-repeat;
    {% if block.settings.background_image %}
      background-image: url({{ block.settings.background_image | image_url: width: 2000 }});
    {% endif %}
  }

  .ai-wellness-hero-container-{{ ai_gen_id }} {
    position: relative;
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
    padding-left: {{ block.settings.container_padding_horizontal }}px;
    padding-right: {{ block.settings.container_padding_horizontal }}px;
    text-align: {{ block.settings.text_align }};
  }

  .ai-wellness-hero-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: {{ block.settings.heading_font_weight }};
    line-height: {{ block.settings.heading_line_height }};
    letter-spacing: {{ block.settings.heading_letter_spacing }};
    text-transform: {{ block.settings.heading_text_transform }};
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-wellness-hero-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_font_size }}px;
    font-weight: {{ block.settings.subtext_font_weight }};
    line-height: {{ block.settings.subtext_line_height }};
    letter-spacing: {{ block.settings.subtext_letter_spacing }};
    margin: 0 0 {{ block.settings.subtext_margin_bottom }}px;
    color: {{ block.settings.subtext_color }};
    opacity: {{ block.settings.subtext_opacity }};
  }

  .ai-wellness-hero-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_top }}px {{ block.settings.button_padding_horizontal }}px {{ block.settings.button_padding_bottom }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    line-height: {{ block.settings.button_line_height }};
    letter-spacing: {{ block.settings.button_letter_spacing }};
    text-transform: {{ block.settings.button_text_transform }};
    text-decoration: none;
    border: {{ block.settings.button_border_width }}px {{ block.settings.button_border_style }} {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    transition: all {{ block.settings.button_transition_duration }}s ease;
    {% if block.settings.enable_button_shadow %}
      box-shadow: {{ block.settings.button_shadow_x }}px {{ block.settings.button_shadow_y }}px {{ block.settings.button_shadow_blur }}px {{ block.settings.button_shadow_spread }}px {{ block.settings.button_shadow_color }};
    {% endif %}
  }

  .ai-wellness-hero-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_color_hover }};
    color: {{ block.settings.button_text_color_hover }};
    border-color: {{ block.settings.button_border_color_hover }};
    {% if block.settings.enable_button_scale %}
      transform: scale({{ block.settings.button_hover_scale }});
    {% endif %}
    {% if block.settings.enable_button_shadow %}
      box-shadow: {{ block.settings.button_shadow_x_hover }}px {{ block.settings.button_shadow_y_hover }}px {{ block.settings.button_shadow_blur_hover }}px {{ block.settings.button_shadow_spread_hover }}px {{ block.settings.button_shadow_color_hover }};
    {% endif %}
  }

  @media screen and (max-width: 768px) {
    .ai-wellness-hero-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-wellness-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_mobile }}px;
      margin-bottom: {{ block.settings.heading_margin_bottom_mobile }}px;
    }

    .ai-wellness-hero-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_font_size_mobile }}px;
      margin-bottom: {{ block.settings.subtext_margin_bottom_mobile }}px;
    }

    .ai-wellness-hero-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size_mobile }}px;
      padding: {{ block.settings.button_padding_top_mobile }}px {{ block.settings.button_padding_horizontal_mobile }}px {{ block.settings.button_padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

<wellness-hero-{{ ai_gen_id }} class="ai-wellness-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-wellness-hero-bg-{{ ai_gen_id }}"></div>
  
  <div class="ai-wellness-hero-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-wellness-hero-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <p class="ai-wellness-hero-subtext-{{ ai_gen_id }}">
        {{ block.settings.subtext }}
      </p>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a 
        href="{{ block.settings.button_link }}" 
        class="ai-wellness-hero-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</wellness-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class WellnessHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('wellness-hero-{{ ai_gen_id }}', WellnessHero{{ ai_gen_id }});
  })();
</script>

