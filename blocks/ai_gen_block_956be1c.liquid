
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
    background: {{ block.settings.section_background_gradient_start }};
    {% if block.settings.enable_gradient %}
      background: linear-gradient(
        {{ block.settings.gradient_angle }}deg,
        {{ block.settings.section_background_gradient_start }} 0%,
        {{ block.settings.section_background_gradient_end }} 100%
      );
    {% endif %}
  }

  .ai-faq-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
    padding-left: {{ block.settings.container_padding_horizontal }}px;
    padding-right: {{ block.settings.container_padding_horizontal }}px;
  }

  .ai-faq-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_text_align }};
    margin-bottom: {{ block.settings.header_margin_bottom }}px;
  }

  .ai-faq-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_font_size }}px;
    font-weight: {{ block.settings.eyebrow_font_weight }};
    text-transform: {{ block.settings.eyebrow_text_transform }};
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }};
    color: {{ block.settings.eyebrow_color }};
    margin-bottom: {{ block.settings.eyebrow_margin_bottom }}px;
    line-height: {{ block.settings.eyebrow_line_height }};
  }

  .ai-faq-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: {{ block.settings.heading_font_weight }};
    color: {{ block.settings.heading_color }};
    line-height: {{ block.settings.heading_line_height }};
    letter-spacing: {{ block.settings.heading_letter_spacing }};
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .ai-faq-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_desktop }}px;
    }
  }

  .ai-faq-accordion-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.accordion_item_spacing }}px;
  }

  .ai-faq-item-{{ ai_gen_id }} {
    background-color: {{ block.settings.item_background_color }};
    border: {{ block.settings.item_border_width }}px {{ block.settings.item_border_style }} {{ block.settings.item_border_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    padding-left: {{ block.settings.item_padding_horizontal }}px;
    padding-right: {{ block.settings.item_padding_horizontal }}px;
    box-shadow: {{ block.settings.item_shadow_x }}px {{ block.settings.item_shadow_y }}px {{ block.settings.item_shadow_blur }}px {{ block.settings.item_shadow_spread }}px {{ block.settings.item_shadow_color }};
    overflow: hidden;
  }

  .ai-faq-question-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    text-align: left;
    background: none;
    border: none;
    padding-top: {{ block.settings.question_padding_vertical }}px;
    padding-bottom: {{ block.settings.question_padding_vertical }}px;
    cursor: pointer;
    font-size: {{ block.settings.question_font_size }}px;
    font-weight: {{ block.settings.question_font_weight }};
    color: {{ block.settings.question_color }};
    line-height: {{ block.settings.question_line_height }};
    letter-spacing: {{ block.settings.question_letter_spacing }};
    transition: color 0.3s ease;
  }

  .ai-faq-question-{{ ai_gen_id }}:hover {
    color: {{ block.settings.question_hover_color }};
  }

  .ai-faq-question-text-{{ ai_gen_id }} {
    flex: 1;
    padding-right: 16px;
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .ai-faq-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
    stroke-width: {{ block.settings.icon_stroke_width }};
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-icon-{{ ai_gen_id }} {
    transform: rotate({{ block.settings.icon_rotation_active }}deg);
  }
  .ai-faq-answer-{{ ai_gen_id }} {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    font-size: {{ block.settings.answer_font_size }}px;
    font-weight: {{ block.settings.answer_font_weight }};
    color: {{ block.settings.answer_color }};
    line-height: {{ block.settings.answer_line_height }};
    letter-spacing: {{ block.settings.answer_letter_spacing }};
  }

  .ai-faq-answer-content-{{ ai_gen_id }} {
    overflow: hidden;
    padding-bottom: 0;
    transition: padding-bottom 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-{{ ai_gen_id }} {
    grid-template-rows: 1fr;
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-content-{{ ai_gen_id }} {
    padding-bottom: {{ block.settings.answer_padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-section-{{ ai_gen_id }} {
      padding-top: {{ block.settings.section_padding_top_mobile }}px;
      padding-bottom: {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-faq-container-{{ ai_gen_id }} {
      padding-left: {{ block.settings.container_padding_horizontal_mobile }}px;
      padding-right: {{ block.settings.container_padding_horizontal_mobile }}px;
    }
  }
{% endstyle %}

<faq-accordion-{{ ai_gen_id }} class="ai-faq-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-faq-container-{{ ai_gen_id }}">
    <div class="ai-faq-header-{{ ai_gen_id }}">
      {% if block.settings.eyebrow_text != blank %}
        <p class="ai-faq-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow_text }}</p>
      {% endif %}
      {% if block.settings.heading_text != blank %}
        <h2 class="ai-faq-heading-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h2>
      {% endif %}
    </div>

    <div class="ai-faq-accordion-{{ ai_gen_id }}">
      {% for i in (1..10) %}
        {% assign question_key = 'faq_question_' | append: i %}
        {% assign answer_key = 'faq_answer_' | append: i %}
        {% assign question = block.settings[question_key] %}
        {% assign answer = block.settings[answer_key] %}

        {% if question != blank and answer != blank %}
          <div class="ai-faq-item-{{ ai_gen_id }}" data-faq-item>
            <button class="ai-faq-question-{{ ai_gen_id }}" aria-expanded="false" data-faq-trigger>
              <span class="ai-faq-question-text-{{ ai_gen_id }}">{{ question }}</span>
              <span class="ai-faq-icon-{{ ai_gen_id }}">
                {% if block.settings.icon_style == 'plus' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <line x1="12" y1="5" x2="12" y2="19" stroke-linecap="round" stroke-linejoin="round"/>
                    <line x1="5" y1="12" x2="19" y2="12" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {% elsif block.settings.icon_style == 'chevron' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <polyline points="6 9 12 15 18 9" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {% elsif block.settings.icon_style == 'arrow' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <line x1="12" y1="5" x2="12" y2="19" stroke-linecap="round" stroke-linejoin="round"/>
                    <polyline points="19 12 12 19 5 12" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {% endif %}
              </span>
            </button>
            <div class="ai-faq-answer-{{ ai_gen_id }}" data-faq-content>
              <div class="ai-faq-answer-content-{{ ai_gen_id }}">
                {{ answer }}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</faq-accordion-{{ ai_gen_id }}>

<script>
  (function() {
    class FaqAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('[data-faq-item]');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          const trigger = item.querySelector('[data-faq-trigger]');
          const content = item.querySelector('[data-faq-content]');

          trigger.addEventListener('click', () => {
            const isActive = item.classList.contains('active');

            {% if block.settings.allow_multiple_open == false %}
              this.items.forEach((otherItem) => {
                if (otherItem !== item) {
                  otherItem.classList.remove('active');
                  const otherTrigger = otherItem.querySelector('[data-faq-trigger]');
                  otherTrigger.setAttribute('aria-expanded', 'false');
                }
              });
            {% endif %}

            if (isActive) {
              item.classList.remove('active');
              trigger.setAttribute('aria-expanded', 'false');
            } else {
              item.classList.add('active');
              trigger.setAttribute('aria-expanded', 'true');
            }
          });
        });

        {% if block.settings.open_first_item %}
          if (this.items.length > 0) {
            const firstItem = this.items[0];
            const firstTrigger = firstItem.querySelector('[data-faq-trigger]');
            firstItem.classList.add('active');
            firstTrigger.setAttribute('aria-expanded', 'true');
          }
        {% endif %}
      }
    }

    customElements.define('faq-accordion-{{ ai_gen_id }}', FaqAccordion{{ ai_gen_id }});
  })();
</script>

