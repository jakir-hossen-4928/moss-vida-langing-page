{% comment %} Vision to Masterpiece - Process Steps Section {% endcomment %}

<style>
  .vtm-section {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.section_padding_top }}px 5% {{ section.settings.section_padding_bottom }}px;
  }

  .vtm-inner {
    max-width: {{ section.settings.section_max_width }}px;
    margin: 0 auto;
  }

  .vtm-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .vtm-eyebrow {
    font-size: {{ section.settings.eyebrow_font_size }}px;
    letter-spacing: 0.2em;
    
    color: {{ section.settings.eyebrow_color }};
    margin: 0 0 12px;
  }

  .vtm-heading {
    font-size: clamp(32px, 5vw, {{ section.settings.heading_font_size }}px);
    color: {{ section.settings.heading_color }};
    margin: 0;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .vtm-grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 4 }}, 1fr);
    gap: {{ section.settings.column_gap }}px;
  }

  @media (max-width: 900px) {
    .vtm-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 32px;
    }
  }

  @media (max-width: 540px) {
    .vtm-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .vtm-number {
    font-size: 48px !important;
}
  }

  .vtm-step {
    display: flex;
    flex-direction: column;
  }

  .vtm-number {
    font-size: {{ section.settings.number_font_size }}px;
    color: {{ section.settings.number_color }};
    line-height: 1;
    margin-bottom: {{ section.settings.number_margin_bottom }}px;
    letter-spacing: -0.02em;
  }

  .vtm-step-title {
    font-size: {{ section.settings.step_title_font_size }}px;
    color: {{ section.settings.step_title_color }};
    margin: 0 0 12px;
    line-height: 1.3;
  }

  .vtm-step-text {
    font-size: {{ section.settings.body_font_size }}px;
    color: {{ section.settings.body_color }};
    line-height: {{ section.settings.body_line_height }};
    margin: 0;
  }

  .vtm-divider {
    width: {{ section.settings.divider_width }}px;
    height: 1px;
    background-color: {{ section.settings.divider_color }};
    margin: {{ section.settings.divider_margin }}px 0;
  }

  {% if section.settings.show_divider == false %}
  .vtm-divider { display: none; }
  {% endif %}
</style>

<section class="vtm-section" id="section-{{ section.id }}">
  <div class="vtm-inner">
    {% if section.settings.eyebrow != blank or section.settings.heading != blank %}
    <div class="vtm-header">
      {% if section.settings.eyebrow != blank %}
        <p class="vtm-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="vtm-heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>
    {% endif %}

    <div class="vtm-grid">
      {% for block in section.blocks %}
        {% if block.type == 'step' %}
        <div class="vtm-step" {{ block.shopify_attributes }}>
          {% if block.settings.number != blank %}
            <div class="vtm-number">{{ block.settings.number }}</div>
          {% endif %}
          <div class="vtm-divider"></div>
          {% if block.settings.title != blank %}
            <h3 class="vtm-step-title">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <p class="vtm-step-text">{{ block.settings.text }}</p>
          {% endif %}
        </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Vision to Masterpiece",
  "tag": "section",
  "class": "vtm-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "The Process"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From Vision to Masterpiece"
    },
    {
      "type": "header",
      "content": "Font Sizes"
    },
    {
      "type": "range",
      "id": "eyebrow_font_size",
      "label": "Eyebrow Font Size (px)",
      "min": 8,
      "max": 30,
      "step": 1,
      "default": 11
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading Font Size (px)",
      "min": 28,
      "max": 80,
      "step": 2,
      "default": 56
    },
    {
      "type": "range",
      "id": "number_font_size",
      "label": "Step Number Font Size (px)",
      "min": 32,
      "max": 120,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "step_title_font_size",
      "label": "Step Title Font Size (px)",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body Font Size (px)",
      "min": 11,
      "max": 20,
      "step": 1,
      "default": 14
    },
    {
      "type": "select",
      "id": "body_line_height",
      "label": "Body Line Height",
      "options": [
        { "value": "1.4", "label": "Tight (1.4)" },
        { "value": "1.6", "label": "Normal (1.6)" },
        { "value": "1.8", "label": "Relaxed (1.8)" },
        { "value": "2.0", "label": "Loose (2.0)" }
      ],
      "default": "1.6"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background",
      "default": "#f0ede6"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Text Color",
      "default": "#c9a99a"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Main Heading Color",
      "default": "#2b2b2b"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Step Number Color",
      "default": "#d9b8b0"
    },
    {
      "type": "color",
      "id": "step_title_color",
      "label": "Step Title Color",
      "default": "#2b2b2b"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body Text Color",
      "default": "#6b6460"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider Line Color",
      "default": "#d9b8b0"
    },
    {
      "type": "header",
      "content": "Layout & Spacing"
    },
    {
      "type": "range",
      "id": "section_max_width",
      "label": "Section Max Width (px)",
      "min": 800,
      "max": 1920,
      "step": 40,
      "default": 1200
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section Padding Top (px)",
      "min": 20,
      "max": 160,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section Padding Bottom (px)",
      "min": 20,
      "max": 160,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column Gap (px)",
      "min": 16,
      "max": 80,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "number_margin_bottom",
      "label": "Space Below Number (px)",
      "min": 4,
      "max": 40,
      "step": 2,
      "default": 16
    },
    {
      "type": "header",
      "content": "Divider Line"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show Divider Line",
      "default": true
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "Divider Width (px)",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 40
    },
    {
      "type": "range",
      "id": "divider_margin",
      "label": "Divider Vertical Margin (px)",
      "min": 4,
      "max": 32,
      "step": 2,
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Process Step",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Step Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Inspiration"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Step Description",
          "default": "Each piece begins with a vision — inspired by the natural world, the play of light through crystals, and the inherent beauty of raw minerals."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vision to Masterpiece",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "01",
            "title": "Inspiration",
            "text": "Each piece begins with a vision — inspired by the natural world, the play of light through crystals, and the inherent beauty of raw minerals."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "02",
            "title": "Selection",
            "text": "We source the finest natural stones, crystals, and 24-karat gold leaf. Every material is hand-selected for its unique character and luminosity."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "03",
            "title": "Creation",
            "text": "Over days and weeks, layers of resin, pigment, and precious materials are meticulously composed — building depth, texture, and a living surface."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "04",
            "title": "Refinement",
            "text": "The final piece is polished, sealed, and prepared for its new home — a singular work of art that will evolve with light and time."
          }
        }
      ]
    }
  ],
  "max_blocks": 8
}
{% endschema %}
