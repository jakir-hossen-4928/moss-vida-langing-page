      "default": "#f9f7f2"
    },
    {
      "type": "color",
      "id": "foreground_color",
      "label": "Foreground",
      "default": "#0c313d"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#5a7a7f"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#d8e9eb"
    }
  ],
  "presets": [
    {
      "name": "MossVida — Footer"
    }
  ]
}
{% endschema %}
