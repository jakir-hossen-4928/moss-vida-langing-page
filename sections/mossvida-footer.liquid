{% comment %}
  MossVida — Custom Footer Section
  Footer with logo, navigation, and copyright
{% endcomment %}

<style>
.mv-footer-section *,
.mv-footer-section *::before,
.mv-footer-section *::after { box-sizing: border-box; margin: 0; padding: 0; }

.mv-footer-section {
  --mv-primary: {{ section.settings.primary_color }};
  --mv-primary-glow: {{ section.settings.primary_glow_color }};
  --mv-ocean-deep: {{ section.settings.ocean_deep_color }};
  --mv-ocean-mid: {{ section.settings.ocean_mid_color }};
  --mv-background: {{ section.settings.background_color }};
  --mv-foreground: {{ section.settings.foreground_color }};
  --mv-muted-foreground: {{ section.settings.muted_color }};
  --mv-border: {{ section.settings.border_color }};
  --mv-card: #ffffff;
  --mv-radius: 1rem;
  --mv-shadow-soft: 0 4px 20px -4px rgba(0,0,0,0.08);
  padding: 3rem 0;
  background: var(--mv-ocean-deep);
  font-family: system-ui, -apple-system, sans-serif;
  color: rgba(255,255,255,0.8);
}

.mv-footer-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 2rem;
}

.mv-footer-top {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  margin-bottom: 2rem;
}

@media (max-width: 768px) {
  .mv-footer-top {
    grid-template-columns: 1fr;
  }
}

.mv-footer-brand {
  max-width: 16rem;
}

.mv-footer-logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
}

.mv-footer-logo-img {
  width: 2.25rem;
  height: 2.25rem;
  border-radius: 9999px;
  object-fit: cover;
}

.mv-footer-logo-text {
  font-size: 1.25rem;
  font-weight: 700;
  color: #ffffff;
}

.mv-footer-brand p {
  font-size: 0.875rem;
  line-height: 1.6;
}

.mv-footer-heading {
  font-size: 1rem;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 0.75rem;
}

.mv-footer-links {
  list-style: none;
}

.mv-footer-links li {
  margin-bottom: 0.5rem;
}

.mv-footer-links a {
  font-size: 0.875rem;
  color: rgba(255,255,255,0.8);
  text-decoration: none;
  transition: color 0.2s;
}

.mv-footer-links a:hover {
  color: var(--mv-primary-glow);
}

.mv-footer-bottom {
  padding-top: 2rem;
  border-top: 1px solid rgba(255,255,255,0.1);
  text-align: center;
  font-size: 0.875rem;
}

@media (max-width: 768px) {
  .mv-footer-container {
    padding: 0 1.5rem;
  }
}
</style>

<footer class="mv-footer-section" role="contentinfo">
  <div class="mv-footer-container">
    <div class="mv-footer-top">
      <div class="mv-footer-brand">
        <div class="mv-footer-logo">
          {%- if section.settings.logo != blank -%}
            {{ section.settings.logo | image_url: width: 200 | image_tag: class: 'mv-footer-logo-img', alt: section.settings.logo_alt | default: shop.name }}
          {%- endif -%}
          <span class="mv-footer-logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
        </div>
        {%- if section.settings.brand_text != blank -%}
          <p>{{ section.settings.brand_text }}</p>
        {%- endif -%}
      </div>

      {%- for col in (1..2) -%}
        <div class="mv-footer-col">
          {%- assign heading_key = 'col_' | append: col | append: '_heading' -%}
          {%- assign heading = section.settings[heading_key] -%}
          {%- if heading != blank -%}
            <h4 class="mv-footer-heading">{{ heading }}</h4>
          {%- endif -%}
          <ul class="mv-footer-links">
            {%- for i in (1..3) -%}
              {%- assign link_key = 'col_' | append: col | append: '_link_' | append: i -%}
              {%- assign url_key = 'col_' | append: col | append: '_url_' | append: i -%}
              {%- assign link = section.settings[link_key] -%}
              {%- assign url = section.settings[url_key] -%}
              {%- if link != blank -%}
                <li><a href="{{ url | default: '#' }}">{{ link }}</a></li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
      {%- endfor -%}
    </div>

    <div class="mv-footer-bottom">
      © {{ 'now' | date: '%Y' }} {{ section.settings.copyright_text | default: shop.name }}. All rights reserved.
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "MossVida — Footer",
  "tag": "section",
  "class": "mv-footer-section-wrap",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Logo alt text",
      "default": "MossVida"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "MossVida"
    },
    {
      "type": "textarea",
      "id": "brand_text",
      "label": "Brand description",
      "default": "Ocean-sourced wellness, crafted with intention. Vegan, organic, made for daily ritual."
    },
    {
      "type": "header",
      "content": "Column 1"
    },
    {
      "type": "text",
      "id": "col_1_heading",
      "label": "Column 1 heading",
      "default": "Shop"
    },
    {
      "type": "text",
      "id": "col_1_link_1",
      "label": "Link 1",
      "default": "Sea Moss Gummies"
    },
    {
      "type": "url",
      "id": "col_1_url_1",
      "label": "Link 1 URL"
    },
    {
      "type": "text",
      "id": "col_1_link_2",
      "label": "Link 2",
      "default": "Benefits"
    },
    {
      "type": "url",
      "id": "col_1_url_2",
      "label": "Link 2 URL"
    },
    {
      "type": "text",
      "id": "col_1_link_3",
      "label": "Link 3",
      "default": "FAQ"
    },
    {
      "type": "url",
      "id": "col_1_url_3",
      "label": "Link 3 URL"
    },
    {
      "type": "header",
      "content": "Column 2"
    },
    {
      "type": "text",
      "id": "col_2_heading",
      "label": "Column 2 heading",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "col_2_link_1",
      "label": "Link 1",
      "default": "Contact"
    },
    {
      "type": "url",
      "id": "col_2_url_1",
      "label": "Link 1 URL"
    },
    {
      "type": "text",
      "id": "col_2_link_2",
      "label": "Link 2",
      "default": "Shipping & returns"
    },
    {
      "type": "url",
      "id": "col_2_url_2",
      "label": "Link 2 URL"
    },
    {
      "type": "text",
      "id": "col_2_link_3",
      "label": "Link 3",
      "default": "Privacy"
    },
    {
      "type": "url",
      "id": "col_2_url_3",
      "label": "Link 3 URL"
    },
    {
      "type": "header",
      "content": "Copyright"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "MossVida"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary teal",
      "default": "#1d7869"
    },
    {
      "type": "color",
      "id": "primary_glow_color",
      "label": "Primary glow aqua",
      "default": "#22c99e"
    },
    {
      "type": "color",
      "id": "ocean_deep_color",
      "label": "Ocean deep",
      "default": "#0c313d"
    },
    {
