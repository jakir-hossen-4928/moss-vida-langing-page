{% comment %}
  GreenBoost — Part 2: Navigation / Header
  Section : gb-header.liquid
  Pattern  : sticky-header custom element (Ella JS) + custom mega menu + self-contained mobile drawer
  Features : sticky scroll behaviour, CSS hover mega menu, JS accordion mobile drawer,
             data-cart-count live badge, schema-controlled colours & logo
{% endcomment %}

<style>
/* ── BOX-SIZING RESET ──────────────────────────────── */
.gb-header-wrap *,
.gb-header-wrap *::before,
.gb-header-wrap *::after { box-sizing: border-box; }
.gb-mobile-overlay, .gb-mobile-overlay *,
.gb-mobile-drawer, .gb-mobile-drawer * { box-sizing: border-box; }

/* ── CSS TOKENS ─────────────────────────────────────── */
:root {
  --gbn-green:      {{ section.settings.accent_color }};
  --gbn-green-dark: {{ section.settings.accent_hover_color }};
  --gbn-bg:         {{ section.settings.nav_bg }};
  --gbn-border:     {{ section.settings.nav_border_color }};
  --gbn-link:       {{ section.settings.link_color }};
  --gbn-link-hover: {{ section.settings.link_hover_color }};
  --gbn-height:     {{ section.settings.nav_height }}px;
  --gbn-max-width:  {{ section.settings.nav_max_width }}px;
}

/* ── STICKY WRAPPER ─────────────────────────────────── */
sticky-header.gb-header-wrap {
  display: block;
  position: fixed;
  /* top is set dynamically by JS to account for ticker/announcement bars above */
  top: 0;
  left: 0;
  right: 0;
  z-index: 200;
  width: 100%;
}

/* sticky_type = none — normal document flow */
sticky-header.gb-header-wrap[data-sticky-type="none"] {
  position: relative;
  left: auto;
  right: auto;
}

/* sticky_type = on_scroll — slides out on scroll-down, back in on scroll-up */
sticky-header.gb-header-wrap[data-sticky-type="on_scroll"] {
  transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}
sticky-header.gb-header-wrap[data-sticky-type="on_scroll"].header--hidden {
  transform: translateY(-110%);
}
/* compensating spacer injected by JS */
.gb-header-spacer { display: none; }

/* ── NAV BAR ────────────────────────────────────────── */
.gb-nav {
  background: var(--gbn-bg);
  border-bottom: 1px solid var(--gbn-border);
  height: var(--gbn-height);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 40px;
  gap: 0;
  transition: box-shadow 0.3s;
}
.gb-nav__inner {
  display: flex;
  align-items: center;
  gap: 40px;
  width: 100%;
  max-width: var(--gbn-max-width);
}
sticky-header.scrolled-past-header .gb-nav {
  box-shadow: 0 2px 16px rgba(0,0,0,0.08);
}

/* ── LOGO ───────────────────────────────────────────── */
.gb-nav__logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  flex-shrink: 0;
}
.gb-nav__logo img { display: block; }
.gb-nav__logo-text {
  font-size: {{ section.settings.logo_font_size }}px;
  font-weight: 800;
  letter-spacing: 2px;
  color: {{ section.settings.logo_color }};
  line-height: 1;
  white-space: nowrap;
}
.gb-nav__logo-text .gb-accent { color: var(--gbn-green); }
.gb-nav__logo-icon {
  display: block;
  width: {{ section.settings.logo_icon_width }}px;
  height: auto;
  flex-shrink: 0;
}

/* ── DESKTOP LINK LIST ──────────────────────────────── */
.gb-nav__links {
  display: flex;
  gap: 28px;
  list-style: none;
  flex: 1;
  justify-content: center;
  margin: 0;
  padding: 0;
}
.gb-nav__links > li > a {
  color: var(--gbn-link);
  text-decoration: none;
  font-size: {{ section.settings.menu_font_size }}px;
  font-weight: 500;
  transition: color 0.2s;
  display: flex;
  align-items: center;
  gap: 5px;
  white-space: nowrap;
}
.gb-nav__links > li > a:hover { color: var(--gbn-link-hover); }

/* chevron arrow */
.gb-chev {
  display: inline-block;
  width: 0;
  height: 0;
  border-left: 4px solid transparent;
  border-right: 4px solid transparent;
  border-top: 5px solid currentColor;
  opacity: 0.45;
  transition: transform 0.2s;
  margin-top: 1px;
  flex-shrink: 0;
}
.gb-nav__dropdown:hover .gb-chev { transform: rotate(180deg); }

/* underline indicator on hover */
.gb-nav__dropdown { position: static; }
.gb-nav__dropdown > a { position: relative; padding-bottom: 2px; }
.gb-nav__dropdown > a::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--gbn-green);
  transform: scaleX(0);
  transition: transform 0.2s;
  transform-origin: left;
}
.gb-nav__dropdown:hover > a::after { transform: scaleX(1); }

/* ── RIGHT ICON CLUSTER ─────────────────────────────── */
.gb-nav__end {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-shrink: 0;
}
.gb-nav__icon {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--gbn-link);
  transition: color 0.2s;
  position: relative;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4px;
  text-decoration: none;
}
.gb-nav__icon:hover { color: var(--gbn-green); }
.gb-nav__icon svg {
  width: 22px;
  height: 22px;
  stroke: currentColor;
  fill: none;
  stroke-width: 1.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}
/* cart count badge — updated by Ella's cart JS via data-cart-count */
.gb-nav__badge {
  position: absolute;
  top: -5px;
  right: -8px;
  background: var(--gbn-green);
  color: #fff;
  font-size: 9px;
  font-weight: 800;
  min-width: 16px;
  height: 16px;
  border-radius: 8px;
  padding: 0 3px;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}
/* shop all CTA button */
.gb-nav__shopall {
  background: var(--gbn-green);
  color: #fff;
  padding: 10px 22px;
  font-size: 14px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  border-radius: 6px;
  text-decoration: none;
  transition: background 0.2s;
  display: inline-block;
  white-space: nowrap;
}
.gb-nav__shopall:hover { background: var(--gbn-green-dark); color: #fff; }

/* ── MEGA MENU PANEL ────────────────────────────────── */
.gb-mega {
  position: fixed;
  top: var(--gbn-height);
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1px solid var(--gbn-border);
  border-bottom: 1px solid var(--gbn-border);
  box-shadow: 0 20px 60px rgba(0,0,0,0.09);
  z-index: 199;
  opacity: 0;
  pointer-events: none;
  transform: translateY(-8px);
  transition: opacity 0.22s, transform 0.22s;
}
.gb-nav__dropdown:hover .gb-mega {
  opacity: 1;
  pointer-events: all;
  transform: translateY(0);
}
.gb-mega__inner {
  display: grid;
  grid-template-columns: 280px 1fr;
  max-width: 1200px;
  margin: 0 auto;
  padding: 48px 64px;
  gap: 72px;
  align-items: start;
}
.gb-mega__eyebrow {
  font-size: 10px;
  letter-spacing: 4px;
  text-transform: uppercase;
  font-weight: 700;
  color: #999;
  margin-bottom: 20px;
}
.gb-mega__links { display: flex; flex-direction: column; }
.gb-mega__links a {
  font-size: 28px;
  font-weight: 800;
  letter-spacing: -0.5px;
  color: #111;
  text-decoration: none;
  padding: 11px 0;
  border-bottom: 1px solid #e0dbd5;
  transition: color 0.15s;
  display: block;
  line-height: 1.15;
}
.gb-mega__links a:first-child { border-top: 1px solid #e0dbd5; }
.gb-mega__links a:hover { color: var(--gbn-green); }
.gb-mega__cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  padding-top: 28px;
}
.gb-mega__card {
  cursor: pointer;
  text-decoration: none;
  display: block;
}
.gb-mega__card-img {
  width: 100%;
  aspect-ratio: 4/3;
  background: #ede9e3;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10px;
  transition: background 0.25s;
}
.gb-mega__card-img img { width: 100%; height: 100%; object-fit: cover; }
.gb-mega__card:hover .gb-mega__card-img { background: #dddad5; }
.gb-mega__card-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}
.gb-mega__card-icon { font-size: 36px; opacity: 0.15; }
.gb-mega__card-note {
  font-size: 9px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: #aaa;
}
.gb-mega__card-label {
  font-size: 13px;
  font-weight: 600;
  color: #2a2a2a;
  transition: color 0.15s;
}
.gb-mega__card:hover .gb-mega__card-label { color: var(--gbn-green); }

/* ── HAMBURGER BUTTON (hidden on desktop) ───────────── */
.gb-nav__hamburger {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  color: var(--gbn-link);
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  transition: color 0.2s;
}
.gb-nav__hamburger:hover { color: var(--gbn-green); }
.gb-nav__hamburger span {
  display: block;
  width: 22px;
  height: 2px;
  background: currentColor;
  border-radius: 2px;
  transition: transform 0.3s, opacity 0.3s;
}
/* animated X state */
.gb-nav__hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.gb-nav__hamburger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.gb-nav__hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ── MOBILE OVERLAY ─────────────────────────────────── */
.gb-mobile-overlay {
  position: fixed;
  inset: 0;
  z-index: 299;
  background: rgba(0, 0, 0, 0.45);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.gb-mobile-overlay.is-open {
  opacity: 1;
  pointer-events: all;
}

/* ── MOBILE DRAWER ──────────────────────────────────── */
.gb-mobile-drawer {
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  width: 320px;
  max-width: 88vw;
  background: #fff;
  z-index: 300;
  transform: translateX(-100%);
  transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  overflow-y: auto;
  overflow-x: hidden;
  display: flex;
  flex-direction: column;
  will-change: transform;
}
.gb-mobile-drawer.is-open { transform: translateX(0); }

/* drawer header */
.gb-mob-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 20px;
  border-bottom: 1px solid #e5e1dc;
  flex-shrink: 0;
}
.gb-mob-head__logo {
  display: flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
  font-size: 15px;
  font-weight: 800;
  letter-spacing: 2px;
  color: #111;
}
.gb-mob-head__logo img { display: block; }
.gb-mob-head__logo .gb-accent { color: var(--gbn-green); }
.gb-mob-close {
  background: none;
  border: none;
  cursor: pointer;
  color: #6b6b6b;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.2s, color 0.2s;
  flex-shrink: 0;
}
.gb-mob-close:hover { background: #f0ece7; color: #111; }
.gb-mob-close svg {
  width: 16px;
  height: 16px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
}

/* drawer nav */
.gb-mob-nav { flex: 1; padding: 8px 0; }
.gb-mob-nav ul { list-style: none; margin: 0; padding: 0; }
.gb-mob-nav > ul > li { border-bottom: 1px solid #f0ece7; }

/* simple link */
.gb-mob-nav > ul > li > a {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 15px 20px;
  font-size: 15px;
  font-weight: 600;
  color: #1a1a1a;
  text-decoration: none;
  transition: color 0.2s, background 0.2s;
}
.gb-mob-nav > ul > li > a:hover { color: var(--gbn-green); background: rgba(61,176,69,0.04); }

/* accordion toggle */
.gb-mob-toggle {
  background: none;
  border: none;
  cursor: pointer;
  padding: 15px 20px;
  font-size: 15px;
  font-weight: 600;
  color: #1a1a1a;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: color 0.2s, background 0.2s;
  text-align: left;
}
.gb-mob-toggle:hover { color: var(--gbn-green); background: rgba(61,176,69,0.04); }
.gb-mob-toggle__chev {
  width: 0;
  height: 0;
  border-left: 4px solid transparent;
  border-right: 4px solid transparent;
  border-top: 5px solid currentColor;
  opacity: 0.5;
  transition: transform 0.25s;
  flex-shrink: 0;
}
.gb-mob-toggle[aria-expanded="true"] .gb-mob-toggle__chev { transform: rotate(180deg); }

/* sub-menu */
.gb-mob-sub {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
  background: #f9f7f5;
}
.gb-mob-sub.is-open { max-height: 600px; }
.gb-mob-sub ul { list-style: none; margin: 0; padding: 0; }
.gb-mob-sub li a {
  display: block;
  padding: 12px 20px 12px 34px;
  font-size: 14px;
  font-weight: 500;
  color: #555;
  text-decoration: none;
  transition: color 0.2s;
}
.gb-mob-sub li a:hover { color: var(--gbn-green); }

/* drawer footer CTAs */
.gb-mob-footer {
  padding: 18px 20px;
  border-top: 1px solid #e5e1dc;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex-shrink: 0;
}
.gb-mob-footer__shopall {
  display: block;
  text-align: center;
  padding: 13px 20px;
  font-size: 14px;
  font-weight: 700;
  background: var(--gbn-green);
  color: #fff;
  border-radius: 50px;
  text-decoration: none;
  transition: background 0.2s;
}
.gb-mob-footer__shopall:hover { background: var(--gbn-green-dark); }
.gb-mob-footer__quiz {
  display: block;
  text-align: center;
  padding: 13px 20px;
  font-size: 14px;
  font-weight: 700;
  color: #111;
  border: 2px solid #111;
  border-radius: 50px;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}
.gb-mob-footer__quiz:hover { background: #111; color: #fff; }

/* ── RESPONSIVE ─────────────────────────────────────── */
@media (max-width: 1024px) {
  .gb-nav { padding: 0 20px; }
  .gb-nav__inner { gap: 0; justify-content: space-between; }
  .gb-nav__links,
  .gb-nav__shopall { display: none; }
  .gb-nav__hamburger { display: flex; flex: 0 0 auto; }
  .gb-nav__logo { flex: 1; justify-content: center; }
  .gb-nav__end { flex: 0 0 auto; }
}
@media (max-width: 480px) {
  .gb-nav { padding: 0 14px; }
  .gb-nav__logo-text { font-size: {{ section.settings.logo_font_size_mobile }}px; }
  .gb-nav__logo-icon { width: {{ section.settings.logo_icon_width_mobile }}px; }
}
</style>

{%- liquid
  assign logo_img    = section.settings.logo
  assign logo_text_1 = section.settings.logo_text_part1
  assign logo_text_2 = section.settings.logo_text_part2
  assign nav_menu    = section.settings.menu
  assign shop_url    = section.settings.shop_all_url
  assign shop_label  = section.settings.shop_all_label
  assign quiz_url    = section.settings.quiz_url
-%}

{%- comment -%} sticky-header is Ella's custom element — handles scroll classes automatically {%- endcomment -%}
<sticky-header data-sticky-type="always" class="gb-header-wrap">

  <nav class="gb-nav" role="navigation" aria-label="{{ shop.name }}">
  <div class="gb-nav__inner">

    <!-- ── HAMBURGER (mobile: far left) ── -->
    <button
      type="button"
      class="gb-nav__hamburger"
      id="gb-hamburger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="gb-drawer">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <!-- ── LOGO ── -->
    <a href="{{ routes.root_url }}" class="gb-nav__logo" aria-label="{{ shop.name }} home">
      {%- if logo_img != blank -%}
        {{- logo_img | image_url: width: 300
            | image_tag: width: section.settings.logo_width,
                         height: 'auto',
                         alt: shop.name,
                         loading: 'eager',
                         fetchpriority: 'high' -}}
      {%- else -%}
        {%- if section.settings.logo_icon != blank -%}
          {{- section.settings.logo_icon
              | image_url: width: 120
              | image_tag: class: 'gb-nav__logo-icon',
                           width: section.settings.logo_icon_width,
                           height: 'auto',
                           alt: '',
                           loading: 'eager' -}}
        {%- else -%}
          <svg class="gb-nav__logo-icon" viewBox="0 0 40 48" fill="none" aria-hidden="true" focusable="false">
            <path d="M20 4C20 4 4 14 4 28C4 38 11 44 20 44C29 44 36 38 36 28C36 14 20 4 20 4Z" fill="{{ section.settings.accent_color }}"/>
            <path d="M20 9C20 9 9 18 9 29C9 37 14 42 20 42" fill="#1e6824" opacity="0.35"/>
            <line x1="20" y1="44" x2="20" y2="33" stroke="{{ section.settings.accent_color }}" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
        {%- endif -%}
        <span class="gb-nav__logo-text">
          {{ logo_text_1 }}<span class="gb-accent">{{ logo_text_2 }}</span>
        </span>
      {%- endif -%}
    </a>

    <!-- ── DESKTOP NAVIGATION ── -->
    <ul class="gb-nav__links" role="list">
      {%- for link in nav_menu.links -%}
        {%- if link.links != blank -%}
          <li class="gb-nav__dropdown">
            <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>
              {{- link.title -}}
              <span class="gb-chev" aria-hidden="true"></span>
            </a>
            <!-- Mega menu panel -->
            <div class="gb-mega" role="region" aria-label="{{ link.title }} menu">
              <div class="gb-mega__inner">
                <!-- Left: sub-links -->
                <div>
                  {%- if section.settings.mega_eyebrow != blank -%}
                    <p class="gb-mega__eyebrow">{{ section.settings.mega_eyebrow }}</p>
                  {%- endif -%}
                  <div class="gb-mega__links">
                    {%- for child in link.links -%}
                      <a href="{{ child.url }}"{% if child.active %} aria-current="page"{% endif %}>{{ child.title }}</a>
                    {%- endfor -%}
                  </div>
                </div>
                <!-- Right: feature cards -->
                <div class="gb-mega__cards">
                  {%- for i in (1..3) -%}
                    {%- assign c_key_label = 'mega_card_' | append: i | append: '_label' -%}
                    {%- assign c_key_url   = 'mega_card_' | append: i | append: '_url' -%}
                    {%- assign c_key_img   = 'mega_card_' | append: i | append: '_image' -%}
                    {%- assign c_key_emoji = 'mega_card_' | append: i | append: '_emoji' -%}
                    {%- assign c_label = section.settings[c_key_label] -%}
                    {%- assign c_url   = section.settings[c_key_url] -%}
                    {%- assign c_img   = section.settings[c_key_img] -%}
                    {%- assign c_emoji = section.settings[c_key_emoji] -%}
                    {%- if c_label != blank -%}
                      <a href="{{ c_url | default: '#' }}" class="gb-mega__card">
                        <div class="gb-mega__card-img">
                          {%- if c_img != blank -%}
                            {{- c_img | image_url: width: 400 | image_tag: loading: 'lazy', width: 400 -}}
                          {%- else -%}
                            <div class="gb-mega__card-placeholder">
                              {%- if c_emoji != blank -%}<span class="gb-mega__card-icon" aria-hidden="true">{{ c_emoji }}</span>{%- endif -%}
                              <span class="gb-mega__card-note">Coming soon</span>
                            </div>
                          {%- endif -%}
                        </div>
                        <span class="gb-mega__card-label">{{ c_label }}</span>
                      </a>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            </div>
          </li>
        {%- else -%}
          <li>
            <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

    <!-- ── RIGHT ICONS ── -->
    <div class="gb-nav__end">

      <!-- Cart — data-cart-count lets Ella's cart JS update the badge live -->
      <a href="{{ routes.cart_url }}" class="gb-nav__icon" aria-label="{{ 'sections.header.cart' | t | default: 'Cart' }}">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="gb-nav__badge" data-cart-count aria-hidden="true">
          {{- cart.item_count -}}
        </span>
      </a>

      <!-- Account -->
      <a href="{{ routes.account_url }}" class="gb-nav__icon" aria-label="{{ 'customer.account.title' | t | default: 'Account' }}">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </a>

      <!-- Shop All CTA -->
      <a href="{{ shop_url | default: routes.all_products_collection_url }}" class="gb-nav__shopall">
        {{- shop_label | default: 'Shop All' -}}
      </a>

    </div><!-- /gb-nav__end -->

  </div><!-- /gb-nav__inner -->
  </nav>

</sticky-header>

<!-- ===== MOBILE BACKDROP ===== -->
<div class="gb-mobile-overlay" id="gb-overlay" aria-hidden="true"></div>

<!-- ===== MOBILE DRAWER ===== -->
<div
  class="gb-mobile-drawer"
  id="gb-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  tabindex="-1">

  <!-- Drawer head -->
  <div class="gb-mob-head">
    <a href="{{ routes.root_url }}" class="gb-mob-head__logo" aria-label="{{ shop.name }} home" tabindex="-1">
      {%- if logo_img != blank -%}
        {{- logo_img | image_url: width: 200
            | image_tag: width: 100, height: 'auto', alt: shop.name, loading: 'lazy' -}}
      {%- else -%}
        <span>{{ logo_text_1 }}<span class="gb-accent">{{ logo_text_2 }}</span></span>
      {%- endif -%}
    </a>
    <button type="button" class="gb-mob-close" id="gb-drawer-close" aria-label="Close navigation menu">
      <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
        <line x1="2" y1="2" x2="14" y2="14"/>
        <line x1="14" y1="2" x2="2" y2="14"/>
      </svg>
    </button>
  </div>

  <!-- Drawer nav -->
  <nav class="gb-mob-nav" aria-label="Mobile navigation">
    <ul role="list">
      {%- for link in nav_menu.links -%}
        {%- if link.links != blank -%}
          <li>
            <button
              type="button"
              class="gb-mob-toggle"
              aria-expanded="false"
              aria-controls="gb-sub-{{ forloop.index }}">
              {{ link.title }}
              <span class="gb-mob-toggle__chev" aria-hidden="true"></span>
            </button>
            <div class="gb-mob-sub" id="gb-sub-{{ forloop.index }}" role="region">
              <ul role="list">
                {%- for child in link.links -%}
                  <li>
                    <a href="{{ child.url }}"{% if child.active %} aria-current="page"{% endif %}>
                      {{ child.title }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          </li>
        {%- else -%}
          <li>
            <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>
              {{ link.title }}
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </nav>

  <!-- Drawer footer CTAs -->
  <div class="gb-mob-footer">
    <a href="{{ shop_url | default: routes.all_products_collection_url }}" class="gb-mob-footer__shopall">
      {{- shop_label | default: 'Shop All' -}}
    </a>
    {%- if quiz_url != blank -%}
      <a href="{{ quiz_url }}" class="gb-mob-footer__quiz">Take the Quiz</a>
    {%- endif -%}
  </div>

</div><!-- /gb-mobile-drawer -->

<script>
(function () {
  'use strict';

  var hamburger = document.getElementById('gb-hamburger');
  var drawer    = document.getElementById('gb-drawer');
  var overlay   = document.getElementById('gb-overlay');
  var closeBtn  = document.getElementById('gb-drawer-close');
  var lastFocus = null;

  /* ── helpers ── */
  function openDrawer() {
    lastFocus = document.activeElement;
    drawer.classList.add('is-open');
    overlay.classList.add('is-open');
    hamburger.classList.add('is-open');
    hamburger.setAttribute('aria-expanded', 'true');
    overlay.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
    drawer.focus();
  }

  function closeDrawer() {
    drawer.classList.remove('is-open');
    overlay.classList.remove('is-open');
    hamburger.classList.remove('is-open');
    hamburger.setAttribute('aria-expanded', 'false');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (lastFocus) lastFocus.focus();
  }

  /* ── triggers ── */
  hamburger.addEventListener('click', function () {
    drawer.classList.contains('is-open') ? closeDrawer() : openDrawer();
  });
  closeBtn.addEventListener('click', closeDrawer);
  overlay.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && drawer.classList.contains('is-open')) closeDrawer();
  });

  /* ── CLOSE DRAWER WHEN ANY MENU LINK IS CLICKED ── */
  drawer.querySelectorAll('a[href]').forEach(function (link) {
    link.addEventListener('click', function () {
      // Small delay to allow navigation to start before closing animation
      setTimeout(closeDrawer, 10);
    });
  });

  /* ── accordion sub-menus ── */
  drawer.querySelectorAll('.gb-mob-toggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var panel  = document.getElementById(this.getAttribute('aria-controls'));
      var isOpen = this.getAttribute('aria-expanded') === 'true';

      /* close all */
      drawer.querySelectorAll('.gb-mob-toggle').forEach(function (b) {
        b.setAttribute('aria-expanded', 'false');
      });
      drawer.querySelectorAll('.gb-mob-sub').forEach(function (s) {
        s.classList.remove('is-open');
      });

      /* open this one if it was closed */
      if (!isOpen) {
        this.setAttribute('aria-expanded', 'true');
        panel.classList.add('is-open');
      }
    });
  });

  /* ── cart count sync ──
     Ella dispatches 'cart:refresh' or updates data-cart-count after add-to-cart.
     This listener keeps our badge in sync with all cart mutations. */
  document.addEventListener('cart:refresh', function () {
    fetch('/cart.js')
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        document.querySelectorAll('[data-cart-count]').forEach(function (el) {
          el.textContent = cart.item_count;
        });
      });
  });

})();

/* ── STICKY BEHAVIOUR ─────────────────────────────────────────────────────
   Self-contained — works for all three sticky_type values without relying
   on Ella's bundled custom-element JS.
   none      → position:relative (CSS handles it, no JS needed)
   always    → position:sticky (CSS default) + scrolled-past-header class
   on_scroll → position:fixed + slide out on scroll-down / in on scroll-up
─────────────────────────────────────────────────────────────────────── */
(function () {
  var header = document.querySelector('sticky-header.gb-header-wrap');
  if (!header) return;

  var stickyType = (header.getAttribute('data-sticky-type') || 'always').trim();

  /* none mode — remove fixed positioning via CSS, no spacer needed */
  if (stickyType === 'none') return;

  /* ── Measure the ticker (section immediately before the header in the DOM) ──
     Keep header at top: tickerHeight - scrollY so it follows the ticker as it
     scrolls away, then locks to top:0 once the ticker is fully gone.          */
  var headerSection = header.closest('.shopify-section') || header.parentNode;
  var prevSection   = headerSection ? headerSection.previousElementSibling : null;
  var tickerHeight  = prevSection ? prevSection.offsetHeight : 0;

  function updateTop() {
    header.style.top = Math.max(0, tickerHeight - window.scrollY) + 'px';
  }
  updateTop();
  window.addEventListener('scroll', updateTop, { passive: true });

  /* ── inject spacer — header height only; ticker stays in normal flow ── */
  var spacer = document.createElement('div');
  spacer.className = 'gb-header-spacer';
  spacer.style.cssText = 'display:block;height:' + header.offsetHeight + 'px;flex-shrink:0;';
  header.parentNode.insertBefore(spacer, header.nextSibling);
  window.addEventListener('load', function () {
    tickerHeight = prevSection ? prevSection.offsetHeight : 0;
    spacer.style.height = header.offsetHeight + 'px';
    updateTop();
  });

  /* ── on_scroll mode — hide on scroll-down, reveal on scroll-up ── */
  if (stickyType === 'on_scroll') {
    var lastY    = window.scrollY;
    var thresh   = header.offsetHeight;
    var ticking  = false;

    window.addEventListener('scroll', function () {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(function () {
        var y = window.scrollY;
        if (y > thresh) {
          header.classList.add('scrolled-past-header');
          if (y > lastY) {
            header.classList.add('header--hidden');
          } else {
            header.classList.remove('header--hidden');
          }
        } else {
          header.classList.remove('scrolled-past-header', 'header--hidden');
        }
        lastY   = y;
        ticking = false;
      });
    }, { passive: true });
    return;
  }

  /* ── always mode — just add shadow class on scroll ── */
  window.addEventListener('scroll', function () {
    header.classList.toggle('scrolled-past-header', window.scrollY > 10);
  }, { passive: true });

})();
</script>

