    },
    {
      "type": "text",
      "id": "nav_link_3",
      "label": "Link 3",
      "default": "How it works"
    },
    {
      "type": "url",
      "id": "nav_url_3",
      "label": "Link 3 URL"
    },
    {
      "type": "text",
      "id": "nav_link_4",
      "label": "Link 4",
      "default": "Reviews"
    },
    {
      "type": "url",
      "id": "nav_url_4",
