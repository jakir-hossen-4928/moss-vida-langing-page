{% comment %}
  MossVida — Fully Customizable "How It Works" Section
{% endcomment %}

<style>
.mv-how-section-{{ section.id }} * { box-sizing: border-box; margin: 0; padding: 0; }

.mv-how-section-{{ section.id }} {
  --mv-primary: {{ section.settings.primary_color }};
  --mv-ocean-deep: {{ section.settings.ocean_deep_color }};
  --mv-background: {{ section.settings.background_color }};
  --mv-muted-foreground: {{ section.settings.muted_color }};
  --mv-border: {{ section.settings.border_color }};
  
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  background: var(--mv-background);
  font-family: system-ui, -apple-system, sans-serif;
}

.mv-how-container-{{ section.id }} {
  max-width: {{ section.settings.container_width }}px;
  margin: 0 auto;
  padding: 0 2rem;
}

.mv-how-header {
  max-width: {{ section.settings.header_max_width }}px;
  margin: 0 auto {{ section.settings.header_margin_bottom }}px;
  text-align: center;
}

.mv-how-kicker {
  font-size: {{ section.settings.kicker_size }}px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--mv-primary);
  margin-bottom: 1rem;
}

.mv-how-h2 {
  font-size: {{ section.settings.heading_size }}px;
  font-weight: 700;
  line-height: 1.1;
  color: var(--mv-ocean-deep);
  letter-spacing: -0.02em;
}

.mv-how-grid {
  display: grid;
  gap: {{ section.settings.grid_gap }}px;
  grid-template-columns: repeat({{ section.settings.cols_mobile }}, 1fr);
}

@media (min-width: 768px) {
  .mv-how-grid { grid-template-columns: repeat({{ section.settings.cols_tablet }}, 1fr); }
}

@media (min-width: 1024px) {
  .mv-how-grid { grid-template-columns: repeat({{ section.settings.cols_desktop }}, 1fr); }
}

.mv-how-card {
  position: relative;
  padding: {{ section.settings.card_padding }}px;
  border-radius: {{ section.settings.card_radius }}px;
  background: linear-gradient(135deg, #ffffff, {{ section.settings.card_bottom }});
  border: 1px solid var(--mv-border);
  box-shadow: 0 4px 20px -4px rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
}

.mv-how-number {
  position: absolute;
  top: {{ section.settings.number_offset_y }}px;
  left: {{ section.settings.number_offset_x }}px;
  font-size: {{ section.settings.number_size }}px;
  font-weight: 700;
  color: var(--mv-primary);
  opacity: {{ section.settings.number_opacity }};
  line-height: 1;
}

.mv-how-h3 {
  font-size: {{ section.settings.step_title_size }}px;
  font-weight: 700;
  color: var(--mv-ocean-deep);
  margin-top: {{ section.settings.title_margin_top }}px;
  margin-bottom: 0.75rem;
}

.mv-how-desc {
  font-size: {{ section.settings.step_desc_size }}px;
  line-height: 1.75;
  color: var(--mv-muted-foreground);
}

@media (max-width: 768px) {
  .mv-how-container-{{ section.id }} { padding: 0 1.5rem; }
}
</style>

<section class="mv-how-section-{{ section.id }}" aria-label="{{ section.settings.aria_label }}">
  <div class="mv-how-container-{{ section.id }}">
    <div class="mv-how-header">
      {%- if section.settings.kicker != blank -%}
        <p class="mv-how-kicker">{{ section.settings.kicker }}</p>
      {%- endif -%}
      <h2 class="mv-how-h2">{{ section.settings.heading }}</h2>
    </div>

    <div class="mv-how-grid">
      {%- for i in (1..3) -%}
        {%- capture num -%}{% if i < 10 %}0{{ i }}{% else %}{{ i }}{% endif %}{%- endcapture -%}
        {%- assign title_key = 'step_title_' | append: i -%}
        {%- assign desc_key = 'step_desc_' | append: i -%}
        {%- assign title = section.settings[title_key] -%}
        {%- assign desc = section.settings[desc_key] -%}
        
        {%- if title != blank or desc != blank -%}
          <div class="mv-how-card">
            <span class="mv-how-number">{{ num }}</span>
            {%- if title != blank -%}<h3 class="mv-how-h3">{{ title }}</h3>{%- endif -%}
            {%- if desc != blank -%}<p class="mv-how-desc">{{ desc }}</p>{%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MossVida — How It Works",
  "settings": [
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container Max Width",
      "min": 1000,
      "max": 1600,
      "step": 10,
      "unit": "px",
      "default": 1280
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 100
    },
    {
      "type": "header",
      "content": "Header Settings"
    },
    { "type": "text", "id": "kicker", "label": "Kicker text", "default": "Simple ritual" },
    {
      "type": "range",
      "id": "kicker_size",
      "label": "Kicker Font Size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Three steps to feeling your best." },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 24,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "header_max_width",
      "label": "Header Max Width",
      "min": 400,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "default": 670
    },
    {
      "type": "range",
      "id": "header_margin_bottom",
      "label": "Header Bottom Margin",
      "min": 20,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 64
    },
    {
      "type": "header",
      "content": "Grid & Card Settings"
    },
    { "type": "range", "id": "cols_desktop", "label": "Desktop Columns", "min": 1, "max": 3, "step": 1, "default": 3 },
    { "type": "range", "id": "cols_tablet", "label": "Tablet Columns", "min": 1, "max": 3, "step": 1, "default": 1 },
    { "type": "range", "id": "cols_mobile", "label": "Mobile Columns", "min": 1, "max": 3, "step": 1, "default": 1 },
    { "type": "range", "id": "grid_gap", "label": "Grid Gap", "min": 10, "max": 60, "step": 5, "unit": "px", "default": 30 },
    { "type": "range", "id": "card_padding", "label": "Card Padding", "min": 20, "max": 80, "step": 2, "unit": "px", "default": 40 },
    { "type": "range", "id": "card_radius", "label": "Card Border Radius", "min": 0, "max": 50, "step": 2, "unit": "px", "default": 24 },
    {
      "type": "header",
      "content": "Step Numbers (Background)"
    },
    { "type": "range", "id": "number_size", "label": "Number Font Size", "min": 30, "max": 120, "step": 2, "unit": "px", "default": 72 },
    { "type": "range", "id": "number_opacity", "label": "Number Opacity", "min": 0, "max": 1, "step": 0.1, "default": 0.2 },
    { "type": "range", "id": "number_offset_x", "label": "Horizontal Position (Left)", "min": -20, "max": 60, "step": 2, "unit": "px", "default": 32 },
    { "type": "range", "id": "number_offset_y", "label": "Vertical Position (Top)", "min": -40, "max": 40, "step": 2, "unit": "px", "default": -24 },
    {
      "type": "header",
      "content": "Card Typography"
    },
    { "type": "range", "id": "step_title_size", "label": "Step Title Size", "min": 18, "max": 40, "step": 1, "unit": "px", "default": 24 },
    { "type": "range", "id": "title_margin_top", "label": "Title Top Margin", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "step_desc_size", "label": "Step Description Size", "min": 14, "max": 24, "step": 1, "unit": "px", "default": 16 },
    {
      "type": "header",
      "content": "Content Steps"
    },
    { "type": "text", "id": "step_title_1", "label": "Step 1 Title", "default": "Take 2 daily" },
    { "type": "textarea", "id": "step_desc_1", "label": "Step 1 Desc", "default": "Two delicious apple gummies with your morning routine." },
    { "type": "text", "id": "step_title_2", "label": "Step 2 Title", "default": "Feel the shift" },
    { "type": "textarea", "id": "step_desc_2", "label": "Step 2 Desc", "default": "Steady energy, clearer skin, calmer digestion." },
    { "type": "text", "id": "step_title_3", "label": "Step 3 Title", "default": "Stay consistent" },
    { "type": "textarea", "id": "step_desc_3", "label": "Step 3 Desc", "default": "Wellness compounds — one bottle is a 30-day reset." },
    {
      "type": "header",
      "content": "Colors"
    },
    { "type": "color", "id": "primary_color", "label": "Primary (Numbers & Kicker)", "default": "#1d7869" },
    { "type": "color", "id": "ocean_deep_color", "label": "Heading Color", "default": "#0c313d" },
    { "type": "color", "id": "background_color", "label": "Section Background", "default": "#f9f7f2" },
    { "type": "color", "id": "card_bottom", "label": "Card Gradient Bottom", "default": "#e8f7f9" },
    { "type": "color", "id": "muted_color", "label": "Description Color", "default": "#5a7a7f" },
    { "type": "color", "id": "border_color", "label": "Card Border", "default": "#d8e9eb" },
    { "type": "text", "id": "aria_label", "label": "ARIA label", "default": "How It Works" }
  ],
  "presets": [
    {
      "name": "MossVida — How It Works"
    }
  ]
}
{% endschema %}