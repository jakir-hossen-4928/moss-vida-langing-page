{% comment %}
  GreenBoost — Part 03: Hero
  Section : gb-hero.liquid
  Source  : GreenBoost_Homepage_Final.html → <!-- HERO -->
  Layout  : CSS grid 1fr 1.05fr — text left, product-box visual right
  Features:
    • Star rating row (schema: rating text)
    • Large editorial headline — Plus Jakarta Sans 800 + Instrument Serif italic accent
    • Subtext paragraph
    • Dual CTAs: green pill (primary) + outline pill (secondary)
    • 3 microcopy trust check items (schema: each label)
    • CSS product open-box visual with 4 branded bottles
      GB-01 Core (gold/tall), GB-02 Aura (rose/wide),
      GB-03 Ease (purple/tall), GB-04 Drive (blue/wide)
    • Floating GMP certified badge (bottom-left of box)
    • Animated scroll cue (bottom-centre of right column)
    • All text, colours, and CTAs schema-controlled
    • Fully responsive — stacks to single column on mobile
{% endcomment %}

<link href="{{ font_link }}" rel="stylesheet">

<style>
/* ── SCOPE RESET ───────────────────────────────────── */
.gb-hero-section *,
.gb-hero-section *::before,
.gb-hero-section *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ── CSS TOKENS ───────────────────────────────────── */
.gb-hero-section {
  --gbh-green:       {{ section.settings.accent_color }};
  --gbh-green-dark:  {{ section.settings.accent_hover_color }};
  --gbh-cream:       {{ section.settings.bg_color }};
  --gbh-cream-dark:  {{ section.settings.image_bg }};
  --gbh-white:       #ffffff;
  --gbh-black:       {{ section.settings.heading_color }};
  --gbh-gray:        {{ section.settings.body_color }};
  --gbh-mid:         #999999;
  --gbh-light:       #e0dbd5;
  --gbh-gold:        {{ section.settings.bottle1_color }};
  --gbh-rose:        {{ section.settings.bottle2_color }};
  --gbh-purple:      {{ section.settings.bottle3_color }};
  --gbh-blue:        {{ section.settings.bottle4_color }};
}

/* ── SECTION WRAPPER ─────────────────────────────────── */
.gb-hero-section {
  background: var(--gbh-cream);
  overflow: hidden;
  font-family: 'Plus Jakarta Sans', sans-serif;
}

/* ── SPLIT GRID ──────────────────────────────────────── */
.gb-hero__grid {
  display: grid;
  grid-template-columns: 1fr 1.05fr;
  min-height: {{ section.settings.min_height }}px;
}

/* ── LEFT COLUMN — Text ──────────────────────────────── */
.gb-hero__left {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 80px 72px 80px 64px;
}

/* Star rating row */
.gb-hero__stars-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 36px;
}
.gb-hero__stars { color: var(--gbh-green); letter-spacing: 2px; font-size: 14px; }
.gb-hero__stars-text { font-size: 13px; color: var(--gbh-gray); }

/* Editorial headline */
.gb-hero__h1 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: clamp(44px, 5vw, {{ section.settings.heading_size }}px);
  font-weight: 800;
  line-height: 1.05;
  letter-spacing: -2.5px;
  color: var(--gbh-black);
  margin-bottom: 28px;
}
.gb-hero__h1 .gb-serif-italic {
  font-family: 'Instrument Serif', serif;
  font-style: italic;
  font-weight: 400;
  color: var(--gbh-green);
  letter-spacing: -1px;
}

/* Sub text */
.gb-hero__sub {
  font-size: 16px;
  color: var(--gbh-gray);
  line-height: 1.75;
  margin-bottom: 44px;
  max-width: 400px;
  font-weight: 400;
}

/* CTA row */
.gb-hero__ctas {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  margin-bottom: 48px;
}
.gb-hero__btn-primary {
  background: var(--gbh-green);
  color: #fff;
  padding: 16px 36px;
  font-size: 15px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  border-radius: 50px;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: background 0.3s, transform 0.3s, box-shadow 0.3s;
  font-family: 'Plus Jakarta Sans', sans-serif;
  white-space: nowrap;
}
.gb-hero__btn-primary:hover {
  background: var(--gbh-green-dark);
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(61,176,69,0.3);
  color: #fff;
}
.gb-hero__btn-secondary {
  background: transparent;
  color: var(--gbh-black);
  padding: 16px 36px;
  font-size: 15px;
  font-weight: 700;
  border: 2px solid var(--gbh-black);
  cursor: pointer;
  border-radius: 50px;
  text-decoration: none;
  display: inline-block;
  transition: background 0.3s, color 0.3s;
  font-family: 'Plus Jakarta Sans', sans-serif;
  white-space: nowrap;
}
.gb-hero__btn-secondary:hover { background: var(--gbh-black); color: #fff; }

/* Microcopy trust checks */
.gb-hero__microcopy { display: flex; flex-direction: column; gap: 10px; }
.gb-hero__check {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: var(--gbh-gray);
}
.gb-hero__check-dot {
  width: 18px; height: 18px;
  border-radius: 50%;
  background: var(--gbh-green);
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; color: #fff; font-weight: 800;
  flex-shrink: 0; line-height: 1;
}

/* ── RIGHT COLUMN — Product visual ──────────────────── */
.gb-hero__right {
  background: var(--gbh-cream-dark);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
  min-height: 560px;
}
.gb-hero__right::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 55% 55%, rgba(61,176,69,0.09) 0%, transparent 65%);
  pointer-events: none;
  z-index: 2;
}

/* Right column background image — no-crop responsive */
.gb-hero__right-img {
  width: 100%;
  height: 100%;
  display: block;
  position: absolute;
  inset: 0;
  object-fit: contain;
  object-position: center center;
  z-index: 1;
}

.gb-hero__product-zone {
  position: relative; z-index: 3;
  display: flex; align-items: flex-end; justify-content: center;
  padding: 60px 20px;
  width: 100%;
  flex: 1;
}
.gb-hero__box {
  width: min(420px, 100%); height: 320px;
  background: linear-gradient(145deg, #e8f4e8, #d8ecda);
  border-radius: 12px 12px 4px 4px;
  position: relative;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 24px 80px rgba(0,0,0,0.08), 0 4px 20px rgba(0,0,0,0.05);
  overflow: hidden;
}
.gb-hero__box-lid {
  position: absolute; top: 0; left: 0; right: 0; height: 120px;
  background: linear-gradient(135deg, #2d6e33, #1e5227);
  border-radius: 12px 12px 0 0;
  display: flex; align-items: center; justify-content: center;
  flex-direction: column; gap: 4px;
}
.gb-hero__lid-text {
  font-family: 'Instrument Serif', serif;
  font-style: italic; font-size: 16px;
  color: rgba(255,255,255,0.85);
  text-align: center; line-height: 1.5;
}
.gb-hero__box-contents {
  position: absolute;
  bottom: 20px; left: 20px; right: 20px;
  display: flex; gap: 12px; align-items: flex-end;
}
.gb-hero__bottle-wrap {
  flex: 1; display: flex; align-items: center; justify-content: center;
  flex-direction: column; gap: 4px; transition: transform 0.3s;
}
.gb-hero__bottle-wrap:hover { transform: translateY(-4px); }
.gb-hero__btl-tall {
  width: 52px; height: 140px;
  background: var(--gbh-white);
  border-radius: 26px 26px 6px 6px;
  border: 1.5px solid var(--gbh-light);
  display: flex; align-items: center; justify-content: center;
  position: relative;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}
.gb-hero__btl-tall::before {
  content: '';
  position: absolute; top: -14px; left: 50%;
  transform: translateX(-50%);
  width: 20px; height: 15px;
  background: var(--gbh-white);
  border: 1.5px solid var(--gbh-light);
  border-radius: 4px 4px 0 0;
}
.gb-hero__btl-wide {
  width: 80px; height: 100px;
  background: var(--gbh-white);
  border-radius: 10px 10px 4px 4px;
  border: 1.5px solid var(--gbh-light);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}
.gb-hero__btl-inner {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 2px; padding: 8px;
}
.gb-hero__btl-brand { font-size: 5px; font-weight: 800; letter-spacing: 2px; color: var(--gbh-green); text-transform: uppercase; }
.gb-hero__btl-name  { font-size: 7px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.5px; text-align: center; }
.gb-hero__btl-code  { font-size: 6px; letter-spacing: 1px; margin-top: 2px; }
/* Bottle uploaded image — overflow kept visible so the cap ::before stays visible */
.gb-hero__btl--has-img { padding: 0; }
.gb-hero__btl-img { width: 100%; height: 100%; object-fit: contain; display: block; border-radius: inherit; }

/* GMP badge */
.gb-hero__gmp-badge {
  position: absolute; bottom: -10px; left: -10px;
  background: var(--gbh-green); color: #fff;
  padding: 12px 16px;
  font-size: 11px; font-weight: 800; letter-spacing: 1px;
  text-transform: uppercase; border-radius: 8px;
  box-shadow: 0 8px 24px rgba(61,176,69,0.4);
  z-index: 3; line-height: 1.4; text-align: center;
  font-family: 'Plus Jakarta Sans', sans-serif;
}
.gb-hero__gmp-badge strong { font-size: 22px; display: block; line-height: 1; }

/* Right column background image — no-crop responsive */
.gb-hero__right-img-wrap {
  position: absolute;
  inset: 0;
  z-index: 1;
  overflow: hidden;
}

/* Scroll cue */
.gb-hero__scroll-cue {
  position: absolute; bottom: 32px; left: 50%;
  transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
  color: var(--gbh-mid);
  animation: gb-hero-pulse 2.5s ease-in-out infinite;
  font-family: 'Plus Jakarta Sans', sans-serif;
}
.gb-hero__scroll-bar {
  width: 1px; height: 36px;
  background: linear-gradient(to bottom, var(--gbh-green), transparent);
}
@keyframes gb-hero-pulse {
  0%,100% { opacity: 0.4; transform: translateX(-50%) translateY(0); }
  50%      { opacity: 1;   transform: translateX(-50%) translateY(5px); }
}

/* ── RESPONSIVE ──────────────────────────────────────── */
@media (max-width: 1024px) {
  .gb-hero__left { padding: 60px 48px 60px 40px; }
  .gb-hero__product-zone { padding: 40px 16px; }
  .gb-hero__box { width: min(360px, 100%); height: 275px; }
  .gb-hero__box-lid { height: 104px; }
  .gb-hero__btl-tall { height: 120px; }
  .gb-hero__btl-wide { width: 68px; height: 86px; }
}
@media (max-width: 768px) {
  .gb-hero__grid { 
    grid-template-columns: 1fr; 
    min-height: unset; 
  }
  {% if section.settings.mobile_visual_direction == 'top' %}
    .gb-hero__right { grid-row: 1; }
    .gb-hero__left { grid-row: 2; }
  {% endif %}
  .gb-hero__left { padding: 52px 24px 40px; }
  .gb-hero__right { min-height: 420px; }
  .gb-hero__box { width: min(340px, 100%); height: 260px; }
  .gb-hero__btl-tall { height: 110px; }
  .gb-hero__btl-wide { width: 64px; height: 80px; }
  .gb-hero__scroll-cue { display: none; }
}
@media (max-width: 480px) {
  .gb-hero__left { padding: 40px 16px 28px; }
  .gb-hero__ctas { flex-direction: column; }
  .gb-hero__btn-primary,
  .gb-hero__btn-secondary { text-align: center; justify-content: center; }
  .gb-hero__box { width: 280px; height: 220px; }
  .gb-hero__btl-tall { width: 40px; height: 90px; }
  .gb-hero__btl-wide { width: 54px; height: 68px; }
  .gb-hero__box-lid { height: 90px; }
  .gb-hero__lid-text { font-size: 13px; }
}
</style>

<section class="gb-hero-section" aria-label="{{ section.settings.aria_label | default: 'Hero' }}">
  <div class="gb-hero__grid"
    {%- unless section.settings.section_width == 'full' -%}
      style="max-width:{{ section.settings.section_width }}px;margin-left:auto;margin-right:auto;"
    {%- endunless -%}
  >

    <!-- ── LEFT — Text column ── -->
    <div class="gb-hero__left">

      {%- if section.settings.show_stars -%}
      <div class="gb-hero__stars-row">
        <span class="gb-hero__stars" aria-hidden="true">★★★★★</span>
        <span class="gb-hero__stars-text">{{ section.settings.stars_text }}</span>
      </div>
      {%- endif -%}

      <h1 class="gb-hero__h1">
        {{ section.settings.heading_line1 }}<br>
        {{ section.settings.heading_line2_plain }}
        {%- if section.settings.heading_line2_italic != blank -%}
          <span class="gb-serif-italic">{{ section.settings.heading_line2_italic }}</span>
        {%- endif -%}
      </h1>

      {%- if section.settings.subtext != blank -%}
        <p class="gb-hero__sub">{{ section.settings.subtext }}</p>
      {%- endif -%}

      <div class="gb-hero__ctas">
        {%- if section.settings.cta1_label != blank -%}
          <a href="{{ section.settings.cta1_url | default: '#' }}" class="gb-hero__btn-primary">
            {{ section.settings.cta1_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta2_label != blank -%}
          <a href="{{ section.settings.cta2_url | default: '#' }}" class="gb-hero__btn-secondary">
            {{ section.settings.cta2_label }}
          </a>
        {%- endif -%}
      </div>

      <div class="gb-hero__microcopy">
        {%- for i in (1..3) -%}
          {%- assign check_key = 'check_' | append: i -%}
          {%- assign check_val = section.settings[check_key] -%}
          {%- if check_val != blank -%}
            <div class="gb-hero__check">
              <div class="gb-hero__check-dot" aria-hidden="true">✓</div>
              {{ check_val }}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div><!-- /gb-hero__left -->

    <!-- ── RIGHT — Product box visual ── -->
    <div class="gb-hero__right"
      {%- capture right_style -%}
        {%- unless section.settings.right_col_shape == 'auto' -%}
          aspect-ratio:{{ section.settings.right_col_shape }};
        {%- endunless -%}
      {%- endcapture -%}
      {%- if right_style != blank -%}style="{{ right_style | strip }}"{%- endif -%}
    >
      {%- if section.settings.right_bg_image != blank -%}
        {%- assign img_fit = section.settings.right_bg_size | default: 'contain' -%}
        {%- assign img_pos = section.settings.right_bg_position | default: 'center center' -%}
        {%- assign img_style = 'position:absolute;inset:0;width:100%;height:100%;object-fit:' | append: img_fit | append: ';object-position:' | append: img_pos | append: ';z-index:1;' -%}
        {{- section.settings.right_bg_image | image_url: width: 1600 | image_tag: class: 'gb-hero__right-img', loading: 'eager', fetchpriority: 'high', style: img_style -}}
      {%- endif -%}

      <div class="gb-hero__product-zone">
        {%- if section.settings.show_box -%}
        <div class="gb-hero__box">

          <div class="gb-hero__box-lid">
            <div class="gb-hero__lid-text">{{ section.settings.lid_text | newline_to_br }}</div>
          </div>

          <div class="gb-hero__box-contents">

            <!-- Bottle 1 — tall, gold -->
            <div class="gb-hero__bottle-wrap">
              {%- if section.settings.bottle1_image != blank -%}
                <div class="gb-hero__btl-tall gb-hero__btl--has-img" style="border-color:{{ section.settings.bottle1_color }}80;">
                  {{- section.settings.bottle1_image | image_url: width: 200 | image_tag: alt: section.settings.bottle1_name, class: 'gb-hero__btl-img', loading: 'eager' -}}
                </div>
              {%- else -%}
                <div class="gb-hero__btl-tall" style="border-color:{{ section.settings.bottle1_color }}80;">
                  <div class="gb-hero__btl-inner">
                    <div class="gb-hero__btl-brand">Green Boost</div>
                    <div class="gb-hero__btl-name" style="color:{{ section.settings.bottle1_color }};">{{ section.settings.bottle1_name }}</div>
                    <div class="gb-hero__btl-code"  style="color:{{ section.settings.bottle1_color }};">{{ section.settings.bottle1_code }}</div>
                  </div>
                </div>
              {%- endif -%}
            </div>

            <!-- Bottle 2 — tall, purple -->
            <div class="gb-hero__bottle-wrap">
              {%- if section.settings.bottle3_image != blank -%}
                <div class="gb-hero__btl-tall gb-hero__btl--has-img" style="border-color:{{ section.settings.bottle3_color }}80;">
                  {{- section.settings.bottle3_image | image_url: width: 200 | image_tag: alt: section.settings.bottle3_name, class: 'gb-hero__btl-img', loading: 'eager' -}}
                </div>
              {%- else -%}
                <div class="gb-hero__btl-tall" style="border-color:{{ section.settings.bottle3_color }}80;">
                  <div class="gb-hero__btl-inner">
                    <div class="gb-hero__btl-brand">Green Boost</div>
                    <div class="gb-hero__btl-name" style="color:{{ section.settings.bottle3_color }};">{{ section.settings.bottle3_name }}</div>
                    <div class="gb-hero__btl-code"  style="color:{{ section.settings.bottle3_color }};">{{ section.settings.bottle3_code }}</div>
                  </div>
                </div>
              {%- endif -%}
            </div>

            <!-- Bottle 3 — wide, rose -->
            <div class="gb-hero__bottle-wrap">
              {%- if section.settings.bottle2_image != blank -%}
                <div class="gb-hero__btl-wide gb-hero__btl--has-img" style="border-color:{{ section.settings.bottle2_color }}80;">
                  {{- section.settings.bottle2_image | image_url: width: 200 | image_tag: alt: section.settings.bottle2_name, class: 'gb-hero__btl-img', loading: 'eager' -}}
                </div>
              {%- else -%}
                <div class="gb-hero__btl-wide" style="border-color:{{ section.settings.bottle2_color }}80;">
                  <div class="gb-hero__btl-inner">
                    <div class="gb-hero__btl-brand">Green Boost</div>
                    <div class="gb-hero__btl-name" style="color:{{ section.settings.bottle2_color }};">{{ section.settings.bottle2_name }}</div>
                    <div class="gb-hero__btl-code"  style="color:{{ section.settings.bottle2_color }};">{{ section.settings.bottle2_code }}</div>
                  </div>
                </div>
              {%- endif -%}
            </div>

            <!-- Bottle 4 — wide, blue -->
            <div class="gb-hero__bottle-wrap">
              {%- if section.settings.bottle4_image != blank -%}
                <div class="gb-hero__btl-wide gb-hero__btl--has-img" style="border-color:{{ section.settings.bottle4_color }}80;">
                  {{- section.settings.bottle4_image | image_url: width: 200 | image_tag: alt: section.settings.bottle4_name, class: 'gb-hero__btl-img', loading: 'eager' -}}
                </div>
              {%- else -%}
                <div class="gb-hero__btl-wide" style="border-color:{{ section.settings.bottle4_color }}80;">
                  <div class="gb-hero__btl-inner">
                    <div class="gb-hero__btl-brand">Green Boost</div>
                    <div class="gb-hero__btl-name" style="color:{{ section.settings.bottle4_color }};">{{ section.settings.bottle4_name }}</div>
                    <div class="gb-hero__btl-code"  style="color:{{ section.settings.bottle4_color }};">{{ section.settings.bottle4_code }}</div>
                  </div>
                </div>
              {%- endif -%}
            </div>

          </div><!-- /box-contents -->

          <div class="gb-hero__gmp-badge">
            <strong>{{ section.settings.badge_headline }}</strong>
            {{ section.settings.badge_subtext | newline_to_br }}
          </div>

        </div><!-- /gb-hero__box -->
        {%- endif -%}
      </div><!-- /gb-hero__product-zone -->

      {%- if section.settings.show_scroll_cue -%}
        <div class="gb-hero__scroll-cue" aria-hidden="true">
          {{ section.settings.scroll_label }}
          <div class="gb-hero__scroll-bar"></div>
        </div>
      {%- endif -%}

    </div><!-- /gb-hero__right -->

  </div><!-- /gb-hero__grid -->
</section>

{% schema %}
{
  "name": "GB — Hero",
  "tag": "section",
  "class": "gb-hero-section-wrap",
  "settings": [
    {
      "type": "header",
      "content": "Star Rating Row"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show star rating row",
      "default": true
    },
    {
      "type": "text",
      "id": "stars_text",
      "label": "Star rating text",
      "default": "5,000+ verified 5-star reviews"
    },
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Headline — line 1",
      "default": "The premium wellness"
    },
    {
      "type": "text",
      "id": "heading_line2_plain",
      "label": "Headline — line 2 plain text",
      "default": "formula for"
    },
    {
      "type": "text",
      "id": "heading_line2_italic",
      "label": "Headline — line 2 italic accent (Instrument Serif green)",
      "info": "Renders in green Instrument Serif italic. Leave blank to hide.",
      "default": "every body."
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Headline max font-size (px)",
      "min": 44,
      "max": 96,
      "step": 2,
      "default": 76
    },
    {
      "type": "header",
      "content": "Subtext"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext paragraph",
      "default": "Five science-backed formulas. Crafted in the USA. Built for people who take their health seriously without overcomplicating it."
    },
    {
      "type": "header",
      "content": "CTAs"
    },
    {
      "type": "text",
      "id": "cta1_label",
      "label": "Primary CTA label",
      "default": "Get Started →"
    },
    {
      "type": "url",
      "id": "cta1_url",
      "label": "Primary CTA URL"
