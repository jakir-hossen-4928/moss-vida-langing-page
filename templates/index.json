    "custom_fqa_kMpAyW": {
      "type": "custom-fqa",
      "blocks": {
        "faq_RKRn7h": {
          "type": "faq",
          "settings": {
            "question": "How long until I see results?",
            "answer": "Most people notice digestive improvement within 7–14 days. Significant changes to gut microbiome balance typically occur over 30–60 days of consistent use. We recommend giving it a full 30 days — which is why we offer a 90-day money-back guarantee."
          }
        },
        "faq_aqDPRP": {
          "type": "faq",
          "settings": {
            "question": "Can I take Green Core with other Green Boost products?",
            "answer": "Absolutely. Green Core is designed to work synergistically with the rest of the Green Boost lineup. It pairs especially well with Green Vitality (GB-05) as a complete daily foundation stack. All five formulas are designed to complement each other without overlap."
          }
        },
        "faq_CiAGw4": {
          "type": "faq",
          "settings": {
            "question": "Is Green Core safe to take every day?",
            "answer": "Yes. Green Core is formulated for daily use and contains only ingredients recognized as safe (GRAS) at the doses provided. It is non-GMO, free of artificial colors, flavors, and sweeteners. Always consult your healthcare provider if you have a medical condition or take medications."
          }
        },
        "faq_8WYWQz": {
          "type": "faq",
          "settings": {
            "question": "What if I want to cancel my subscription?",
            "answer": "No problem — cancellation is completely hassle-free. Log in to your account, go to Subscriptions, and cancel anytime. You can also skip a month, change your delivery frequency, or pause — all from your account dashboard."
          }
        },
        "faq_RCQ9EV": {
          "type": "faq",
          "settings": {
            "question": "Does Green Core contain any allergens?",
            "answer": "Green Core is free from gluten, soy, dairy, nuts, and shellfish. It is manufactured in a facility that processes these allergens. Full ingredient and allergen information is available in the Supplement Facts panel."
          }
        },
        "faq_6WRCMn": {
          "type": "faq",
          "settings": {
            "question": "What is your money-back guarantee?",
            "answer": "We offer a full 90-day money-back guarantee. If you're not completely satisfied with Green Core for any reason within 90 days of purchase, contact our support team for a full refund — no questions asked. This applies to first-time purchases."
          }
        }
      },
